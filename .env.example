# MongoDB – use either URI (Node/mongoose) or Data API (Cloudflare/fetch)

# Option 1: Connection URI (mongoose, works in Node – nuxt dev, VPS, etc.)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Option 2: Data API / App Services (fetch, works on Cloudflare)
# MONGODB_APP_ID=your-app-id
# MONGODB_API_KEY=your-data-api-key
# MONGODB_DATA_SOURCE=Cluster0
# MONGODB_DATABASE=mydb

# Force Data API even when MONGODB_URI is set (switch back to App Services)
# MONGODB_USE_DATA_API=true

API_URL=https://weather.hantha.digital
CRON_SECRET=your-cron-secret
WEATHERLINK_API_KEY=your-key
WEATHERLINK_API_SECRET=your-secret

# PWS (Weather.com) — https://developer.weather.com
WEATHER_COM_API_KEY=your-weather-com-api-key
# Optional (ms): success cache / error cache / min interval between 401 log lines
# PWS_OBSERVATIONS_CURRENT_CACHE_TTL_MS=60000
# PWS_OBSERVATIONS_ERROR_CACHE_TTL_MS=300000
# PWS_401_LOG_INTERVAL_MS=120000
