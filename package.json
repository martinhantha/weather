{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node ./node_modules/esbuild/install.js",
    "build": "yarn build:widget && nuxt build",
    "build:widget": "cd widget && yarn install && yarn build && mkdir -p ../public && cp -r dist/* ../public/",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "start": "nuxt start",
    "deploy:cloudflare": "yarn build && npx wrangler --cwd dist pages deploy . --branch master --project-name=weather",
    "preview:cloudflare": "yarn build && npx wrangler --cwd dist pages dev",
    "test:mongo": "node --env-file=.env scripts/test-mongo.js",
    "poll:measurement": "node --env-file=.env scripts/poll-measurement.mjs"
  },
  "devDependencies": {
    "@nuxt/devtools": "latest",
    "@nuxtjs/tailwindcss": "^6.9.5",
    "autoprefixer": "^10.4.16",
    "mongoose": "^8.0.0",
    "mongoose-bcrypt": "^1.11.0",
    "nuxt": "^3.8.0",
    "nuxt-scheduler": "^0.1.9",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.4.15",
    "vue": "^3.3.7",
    "vue-router": "^4.2.5"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "less": "^4.2.0",
    "nuxt-server-utils": "^0.0.7"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
